# Copy to .env and fill in your values. Never commit .env.

# WordPress — Application Passwords (Users → <user> → Application Passwords)
{{PROJECT_UPPER}}_WP_USER=
{{PROJECT_UPPER}}_WP_PASS=
{{PROJECT_UPPER}}_STAGE_WP_USER=
{{PROJECT_UPPER}}_STAGE_WP_PASS=

# Optional — infra / AI APIs
HOSTINGER_API_TOKEN=
OPENROUTER_API_KEY=
