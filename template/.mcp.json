{
  "mcpServers": {
    "hostinger-api": {
      "type": "stdio",
      "command": "hostinger-api-mcp",
      "env": {
        "API_TOKEN": "${env:HOSTINGER_API_TOKEN}",
        "DEBUG": "false"
      }
    },
    "{{PROJECT_SLUG}}-prod": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@automattic/mcp-wordpress-remote@latest"],
      "env": {
        "WP_API_URL": "https://{{PROD_URL}}/wp-json/mcp/mcp-adapter-default-server",
        "WP_API_USERNAME": "${env:{{PROJECT_UPPER}}_WP_USER}",
        "WP_API_PASSWORD": "${env:{{PROJECT_UPPER}}_WP_PASS}"
      }
    },
    "{{PROJECT_SLUG}}-stage": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@automattic/mcp-wordpress-remote@latest"],
      "env": {
        "WP_API_URL": "https://{{STAGE_URL}}/wp-json/mcp/mcp-adapter-default-server",
        "WP_API_USERNAME": "${env:{{PROJECT_UPPER}}_STAGE_WP_USER}",
        "WP_API_PASSWORD": "${env:{{PROJECT_UPPER}}_STAGE_WP_PASS}"
      }
    }
  }
}
