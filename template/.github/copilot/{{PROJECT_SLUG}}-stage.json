{
    "servers": {
        "{{PROJECT_SLUG}}-stage": {
            "command": "npx",
            "args": ["-y", "@automattic/mcp-wordpress-remote@latest"],
            "env": {
                "WP_API_URL": "https://{{STAGE_URL}}/wp-json/mcp/mcp-adapter-default-server",
                "WP_API_USERNAME": "${env:{{PROJECT_UPPER}}_STAGE_WP_USER}",
                "WP_API_PASSWORD": "${env:{{PROJECT_UPPER}}_STAGE_WP_PASS}"
            }
        }
    }
}
